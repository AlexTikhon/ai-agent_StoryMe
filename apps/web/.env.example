# Not needed for local dev (apiFetch/asset-url default to http://localhost:4000/api).
# Set this in production/staging so the web app calls the deployed API instead
# of localhost. Must be reachable from the browser (client-side fetches), not
# just from the web server. Required in production builds (NODE_ENV=production)
# — getApiBase() throws rather than silently falling back to localhost if unset.
NEXT_PUBLIC_API_URL="https://api.example.com/api"

# NEXT_PUBLIC_AUTH_MODE: dev | jwt. Defaults to "jwt" (real login/register,
# in-memory access token, HttpOnly refresh cookie) when unset, matching the
# API's own AUTH_MODE default — a deployment that forgets to set this is safe.
# Set to "dev" only for local convenience against an API running with
# AUTH_MODE=dev: every request carries a hardcoded x-user-email/x-user-name
# pair instead of a bearer token, no login screen, and the dashboard is never
# gated. Must match the API's AUTH_MODE — a mismatch means every request 401s.
NEXT_PUBLIC_AUTH_MODE="jwt"
