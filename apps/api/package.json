{
  "name": "@book/api",
  "version": "0.0.1",
  "private": true,
  "description": "StoryMe NestJS API",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "nest start --watch",
    "start": "node dist/main",
    "lint": "eslint src --max-warnings 0",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "render:pdf": "ts-node -r tsconfig-paths/register --project tsconfig.scripts.json scripts/render-pdf.ts",
    "smoke:pdf-storage": "ts-node -r tsconfig-paths/register --project tsconfig.scripts.json scripts/smoke-cloud-pdf-storage.ts",
    "smoke:real-generation": "ts-node -r tsconfig-paths/register --project tsconfig.scripts.json scripts/smoke-real-generation.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.632.0",
    "@book/types": "workspace:*",
    "@nestjs/bullmq": "^10.2.1",
    "pdfkit": "^0.15.0",
    "@nestjs/common": "^10.3.10",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.3.10",
    "@nestjs/platform-express": "^10.3.10",
    "@nestjs/terminus": "^10.2.3",
    "@prisma/client": "^5.17.0",
    "bullmq": "^5.12.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/pdfkit": "^0.13.0",
    "@nestjs/cli": "^10.4.5",
    "@nestjs/schematics": "^10.1.4",
    "@nestjs/testing": "^10.3.10",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.14",
    "@vitest/coverage-v8": "^2.0.5",
    "prisma": "^5.17.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}
