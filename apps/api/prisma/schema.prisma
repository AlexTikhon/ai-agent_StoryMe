// schema.prisma — StoryMe MVP Database Schema
// Version: 1.0 | 2026-06-30
// Source of truth: PRD.md, API_SPEC.md, BACKEND_DESIGN.md, ARCHITECTURE.md

generator client {
  provider      = "prisma-client-js"
  // "native" covers local dev (Windows/macOS/glibc Linux); the Docker image
  // builds and runs on Alpine (musl) with OpenSSL 3.x, so that target is
  // pinned explicitly rather than relying on runtime libssl detection.
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════
// ENUMS
// ═══════════════════════════════════════════

enum UserPlan {
  free
  pay_per_book
  family
  annual
  educator
}

enum UserRole {
  user
  admin
}

// DB-stored values use the slash form ("he/him") to match API contract
enum Pronouns {
  he_him    @map("he/him")
  she_her   @map("she/her")
  they_them @map("they/them")
}

// Phase 1A: languages supported by the simple book-draft creation flow.
enum BookLanguage {
  en
  ru
  pl
}

// Mirrors the pipeline state machine in BACKEND_DESIGN §3.12
//
// `partial` and `cancelled` are reserved terminal states for future
// generation-workflow features (partial-completion recovery, user-initiated
// cancellation — see ROADMAP.md). No code path in the current MVP pipeline
// sets a Book to either status; they're kept here (and handled defensively
// as terminal in generation-job-recovery.service.ts and the web book-detail
// page) so those features can land without a state-machine migration later.
enum BookStatus {
  created
  char_build
  story_plan
  page_plan
  story_draft
  chapter_gen
  illust_plan
  preview_ready
  image_gen
  qa_review
  layout
  pdf_render
  complete
  failed
  partial
  cancelled
}

// All pipeline steps — used in AgentLog and failedStep on Book
enum AgentStep {
  char_build
  story_plan
  page_plan
  story_draft
  chapter_gen
  illust_plan
  preview_ready
  char_consistency
  image_gen
  qa_review
  layout
  pdf_render
}

enum AgentLogStatus {
  success
  error
  retry
}

enum CreditReason {
  book_creation
  regen_page
  refund_generation_failure
  purchase
  subscription_grant
  promotional_grant
  admin_adjustment
}

enum SubscriptionStatus {
  active
  past_due
  cancelled
  trialing
}

enum UploadStatus {
  pending
  processing
  complete
  failed
}

enum ShareLinkMode {
  preview_only
  full_read
}

enum NotificationType {
  generation_complete
  generation_failed
  birthday_reminder
  subscription_renewed
  payment_failed
  marketing
  newsletter
}

enum NotificationChannel {
  email
  push
}

// Phase 3I: generation job tracking — see GenerationJob model below
enum GenerationJobType {
  generate
  retry
}

enum GenerationJobStatus {
  queued
  running
  completed
  failed
  cancelled
}

// Phase 2A (production-safety hardening): the GenerationRun aggregate
// replaces GenerationJob as the source of truth for dispatch/fencing —
// GenerationJob stays in the schema (unused by new code) until a separate
// cleanup migration removes it. See docs/local-generation-pipeline.md
// "Generation runs" once Phase 2B wires this in.
enum GenerationRunKind {
  initial
  retry
  regenerate
}

enum GenerationRunStatus {
  queued
  running
  completed
  failed
}

// ═══════════════════════════════════════════
// USER & AUTH
// ═══════════════════════════════════════════

model User {
  id            String    @id @default(uuid()) @db.Uuid
  email         String    @unique
  passwordHash  String?   @map("password_hash")
  name          String?
  locale        String    @default("en")
  timezone      String    @default("UTC")
  avatarUrl     String?   @map("avatar_url")

  oauthProvider String?   @map("oauth_provider")
  oauthId       String?   @map("oauth_id")

  plan             UserPlan  @default(free)
  credits          Int       @default(3)
  creditsUpdatedAt DateTime? @map("credits_updated_at")

  role          UserRole  @default(user)
  emailVerified Boolean   @default(false) @map("email_verified")
  emailVerifiedAt            DateTime? @map("email_verified_at")
  // Only a hash of the verification token is ever stored — see AuthService.
  // Unique so a hash collision can never verify the wrong account; null for
  // users with no pending verification (never sent, or already verified).
  emailVerificationTokenHash String?   @unique @map("email_verification_token_hash")
  emailVerificationExpiresAt DateTime? @map("email_verification_expires_at")
  // Only a hash of the reset token is ever stored — see AuthService. Unique
  // so a hash collision can never reset the wrong account; null when there is
  // no pending reset (never requested, expired and superseded, or consumed).
  passwordResetTokenHash     String?   @unique @map("password_reset_token_hash")
  passwordResetExpiresAt     DateTime? @map("password_reset_expires_at")
  passwordResetRequestedAt   DateTime? @map("password_reset_requested_at")
  deactivatedAt DateTime? @map("deactivated_at")

  notifyEmailOnCompletion Boolean @default(true)  @map("notify_email_on_completion")
  notifyEmailMarketing    Boolean @default(false) @map("notify_email_marketing")
  notifyPushOnCompletion  Boolean @default(true)  @map("notify_push_on_completion")
  notifyBirthdayReminders Boolean @default(true)  @map("notify_birthday_reminders")

  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  refreshTokens      RefreshToken[]
  childProfiles      ChildProfile[]
  uploads            Upload[]
  books              Book[]
  characterCards     CharacterCard[]
  series             BookSeries[]
  creditTransactions CreditTransaction[]
  subscription       Subscription?
  wizardDraft        WizardDraft?
  userBookStates     UserBookState[]
  notifications      Notification[]

  @@index([email])
  @@index([oauthProvider, oauthId])
  @@map("users")
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  family    String    @db.Uuid
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  ipAddress String?   @map("ip_address")
  userAgent String?   @map("user_agent")
  createdAt DateTime  @default(now()) @map("created_at")

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([family])
  @@map("refresh_tokens")
}

// ═══════════════════════════════════════════
// CHILD PROFILES
// ═══════════════════════════════════════════

model ChildProfile {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  name         String
  nickname     String?
  age          Int
  pronouns     Pronouns  @default(they_them)
  avatarConfig Json?     @map("avatar_config")
  photoAssetId String?   @map("photo_asset_id") @db.Uuid
  birthday     DateTime? @db.Date

  deletedAt    DateTime? @map("deleted_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  photo          Upload?       @relation(fields: [photoAssetId], references: [id], onDelete: SetNull)
  books          Book[]
  characterCards CharacterCard[]

  @@index([userId])
  @@map("child_profiles")
}

// ═══════════════════════════════════════════
// UPLOADS
// ═══════════════════════════════════════════

model Upload {
  id               String       @id @default(uuid()) @db.Uuid
  userId           String       @map("user_id") @db.Uuid
  status           UploadStatus @default(pending)
  filename         String
  contentType      String       @map("content_type")
  fileSizeBytes    Int          @map("file_size_bytes")
  r2Key            String       @map("r2_key")
  processedR2Key   String?      @map("processed_r2_key")
  processedUrl     String?      @map("processed_url")
  failureReason    String?      @map("failure_reason")
  imageWidth       Int?         @map("image_width")
  imageHeight      Int?         @map("image_height")
  presignExpiresAt DateTime?    @map("presign_expires_at")
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  childProfiles    ChildProfile[]

  @@index([userId])
  @@map("uploads")
}

// ═══════════════════════════════════════════
// BOOKS
// ═══════════════════════════════════════════

model Book {
  id               String      @id @default(uuid()) @db.Uuid
  userId           String      @map("user_id") @db.Uuid
  childProfileId   String?     @map("child_profile_id") @db.Uuid

  // BookStatus.created doubles as the Phase 1A "draft" state — editable/deletable
  // until the generation pipeline (Phase 1B+) advances it to a later status.
  status           BookStatus  @default(created)
  // Optional in Phase 1A: the simple draft-creation form doesn't populate the
  // full wizard payload yet. Required once the Phase 1B+ wizard lands.
  request          Json?
  title            String?
  dedicationText   String?     @map("dedication_text")
  pageCount        Int?        @map("page_count")

  // Phase 1A draft fields — minimal book-creation form, set directly on Book
  // ahead of the full ChildProfile-driven wizard.
  childName        String?     @map("child_name")
  childAge         Int?        @map("child_age")
  language         BookLanguage?
  theme            String?
  // Phase 4A: user-supplied desired educational message/lesson, distinct from
  // the generated storyPlan.educationalMessage produced by the pipeline.
  educationalMessage String?   @map("educational_message")

  characterCard         Json?       @map("character_card")
  storyPlan             Json?       @map("story_plan")
  bookPreview           Json?       @map("book_preview")
  imageGenerationResult Json?       @map("image_generation_result")
  bookLayout            Json?       @map("book_layout")

  // Personalized character generation: optional uploaded reference photo,
  // the stylized CharacterProfile built from it (never a realistic
  // portrait), and an optional generated character-sheet reference image.
  // Both asset keys are ImageAssetStorage keys (see image-asset-storage.ts),
  // not URLs — resolved through the same local/cloud storage driver as
  // generated illustrations.
  childPhotoAssetKey       String?  @map("child_photo_asset_key")
  childPhotoContentType    String?  @map("child_photo_content_type")
  characterProfile         Json?    @map("character_profile")
  characterSheetAssetKey   String?  @map("character_sheet_asset_key")
  chapters              Json?
  imagePrompts     Json?       @map("image_prompts")
  qualityReport    Json?       @map("quality_report")
  pageLayouts      Json?       @map("page_layouts")

  coverUrl         String?     @map("cover_url")
  pdfR2Key         String?     @map("pdf_r2_key")
  pdfUrl           String?     @map("pdf_url")
  printPdfR2Key    String?     @map("print_pdf_r2_key")
  printPdfUrl      String?     @map("print_pdf_url")
  previewPdfR2Key  String?     @map("preview_pdf_r2_key")
  previewPdfUrl    String?     @map("preview_pdf_url")
  socialCardUrl    String?     @map("social_card_url")

  isPaid           Boolean     @default(false) @map("is_paid")
  paidAt           DateTime?   @map("paid_at")
  stripePaymentIntentId String? @map("stripe_payment_intent_id")

  isPublic         Boolean     @default(false) @map("is_public")

  generationTimeMs  Int?       @map("generation_time_ms")
  totalCostUsd      Decimal?   @map("total_cost_usd") @db.Decimal(10, 6)
  aiModelVersions   Json?      @map("ai_model_versions")
  generatedDegraded Boolean    @default(false) @map("generated_degraded")

  errorMessage     String?     @map("error_message")
  retryCount       Int         @default(0) @map("retry_count")
  failedStep       AgentStep?  @map("failed_step")

  // Phase 2A (production-safety hardening) — not yet read/written by any
  // code path; wired in by Phase 2B. activeRunId is cleared when the run it
  // points at reaches a terminal state; publishedRunId is updated only on a
  // run's successful completion, so the last successful output stays
  // referenced while a later run is in flight or fails (invariant G in
  // docs/local-generation-pipeline.md). Plain UUID columns, not Prisma
  // relations, to avoid a 3-way relation-naming tangle with GenerationRun's
  // own bookId relation below — nothing here depends on FK-level cascade
  // behavior for correctness (see GenerationRun.retryOfRunId for the same
  // reasoning).
  activeRunId      String?     @map("active_run_id") @db.Uuid
  publishedRunId   String?     @map("published_run_id") @db.Uuid

  // Phase 2D — the GenerationRun.inputHash that produced the story/character/
  // image JSON currently stored on this row, if any. AgentService.
  // isResumableBook compares this against the run it's currently executing:
  // only an exact hash match means the input hasn't changed since these
  // artifacts were generated, and only then may they be reused. This is what
  // stops a retry/regenerate from silently reusing stale content after the
  // book was edited (previously any prior JSON was reused unconditionally —
  // see AgentService's old isResumableBook doc comment).
  lastGenerationInputHash String? @map("last_generation_input_hash")

  deletedAt        DateTime?   @map("deleted_at")
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")

  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  childProfile     ChildProfile? @relation(fields: [childProfileId], references: [id], onDelete: SetNull)
  pages            BookPage[]
  shareLinks       ShareLink[]
  creditTransactions CreditTransaction[]
  userBookStates   UserBookState[]
  agentLogs        AgentLog[]
  generationJobs   GenerationJob[]
  generationRuns   GenerationRun[]

  @@index([userId])
  @@index([status])
  @@index([userId, status])
  @@index([userId, createdAt(sort: Desc)])
  @@map("books")
}

// ═══════════════════════════════════════════
// BOOK PAGES
// ═══════════════════════════════════════════

model BookPage {
  id               String    @id @default(uuid()) @db.Uuid
  bookId           String    @map("book_id") @db.Uuid
  pageNumber       Int       @map("page_number")

  textContent      String?   @map("text_content")
  readingLevel     Decimal?  @map("reading_level") @db.Decimal(3, 1)

  imagePrompt      Json?     @map("image_prompt")
  imageR2Key       String?   @map("image_r2_key")
  imageUrl         String?   @map("image_url")
  imageSeed        BigInt?   @map("image_seed")

  layoutSpec       Json?     @map("layout_spec")

  qaPassed         Boolean?  @map("qa_passed")
  qaScores         Json?     @map("qa_scores")

  textRegenCount   Int       @default(0) @map("text_regen_count")
  imageRegenCount  Int       @default(0) @map("image_regen_count")

  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  book             Book      @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([bookId, pageNumber])
  @@index([bookId])
  @@map("book_pages")
}

// ═══════════════════════════════════════════
// CHARACTER CARDS
// ═══════════════════════════════════════════

model CharacterCard {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  childProfileId   String?   @map("child_profile_id") @db.Uuid
  name             String
  card             Json
  visualAnchor     String    @map("visual_anchor")
  loraWeightsR2Key String?   @map("lora_weights_r2_key")
  loraTrainedAt    DateTime? @map("lora_trained_at")
  createdAt        DateTime  @default(now()) @map("created_at")

  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  childProfile     ChildProfile?  @relation(fields: [childProfileId], references: [id], onDelete: SetNull)
  series           BookSeries[]

  @@index([userId])
  @@map("character_cards")
}

// ═══════════════════════════════════════════
// BOOK SERIES
// ═══════════════════════════════════════════

model BookSeries {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String    @map("user_id") @db.Uuid
  name            String
  characterCardId String?   @map("character_card_id") @db.Uuid
  bookIds         String[]  @default([]) @map("book_ids") @db.Uuid
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  characterCard   CharacterCard? @relation(fields: [characterCardId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@map("series")
}

// ═══════════════════════════════════════════
// WIZARD DRAFTS
// ═══════════════════════════════════════════

model WizardDraft {
  id             String    @id @default(uuid()) @db.Uuid
  userId         String?   @unique @map("user_id") @db.Uuid
  guestSessionId String?   @unique @map("guest_session_id")
  step           Int       @default(1)
  completedSteps Int[]     @default([]) @map("completed_steps")
  data           Json
  childProfileId String?   @map("child_profile_id") @db.Uuid
  expiresAt      DateTime  @map("expires_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  user           User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([guestSessionId])
  @@map("wizard_drafts")
}

// ═══════════════════════════════════════════
// SHARE LINKS
// ═══════════════════════════════════════════

model ShareLink {
  id           String        @id @default(uuid()) @db.Uuid
  bookId       String        @map("book_id") @db.Uuid
  token        String        @unique
  mode         ShareLinkMode @default(preview_only)
  passwordHash String?       @map("password_hash")
  expiresAt    DateTime?     @map("expires_at")
  revokedAt    DateTime?     @map("revoked_at")
  viewCount    Int           @default(0) @map("view_count")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  book         Book          @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@index([bookId])
  @@index([token])
  @@map("share_links")
}

// ═══════════════════════════════════════════
// CREDIT TRANSACTIONS
// ═══════════════════════════════════════════

model CreditTransaction {
  id              String       @id @default(uuid()) @db.Uuid
  userId          String       @map("user_id") @db.Uuid
  bookId          String?      @map("book_id") @db.Uuid
  amount          Int
  balanceAfter    Int          @map("balance_after")
  reason          CreditReason
  stripePaymentId String?      @map("stripe_payment_id")
  createdAt       DateTime     @default(now()) @map("created_at")

  user            User         @relation(fields: [userId], references: [id])
  book            Book?        @relation(fields: [bookId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([bookId])
  @@index([userId, createdAt(sort: Desc)])
  @@map("credit_transactions")
}

// ═══════════════════════════════════════════
// SUBSCRIPTIONS
// ═══════════════════════════════════════════

model Subscription {
  id                   String             @id @default(uuid()) @db.Uuid
  userId               String             @unique @map("user_id") @db.Uuid
  stripeCustomerId     String             @map("stripe_customer_id")
  stripeSubscriptionId String?            @unique @map("stripe_subscription_id")
  plan                 UserPlan
  status               SubscriptionStatus @default(active)
  currentPeriodStart   DateTime?          @map("current_period_start")
  currentPeriodEnd     DateTime?          @map("current_period_end")
  cancelAtPeriodEnd    Boolean            @default(false) @map("cancel_at_period_end")
  cancelledAt          DateTime?          @map("cancelled_at")
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")

  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([stripeCustomerId])
  @@map("subscriptions")
}

// ═══════════════════════════════════════════
// AGENT LOGS
// ═══════════════════════════════════════════

model AgentLog {
  id           String         @id @default(uuid()) @db.Uuid
  bookId       String         @map("book_id") @db.Uuid
  agent        String
  step         AgentStep
  provider     String?
  model        String?
  durationMs   Int?           @map("duration_ms")
  tokensInput  Int?           @map("tokens_input")
  tokensOutput Int?           @map("tokens_output")
  costUsd      Decimal?       @map("cost_usd") @db.Decimal(10, 6)
  attempt      Int            @default(1)
  status       AgentLogStatus
  error        String?
  traceId      String?        @map("trace_id")
  createdAt    DateTime       @default(now()) @map("created_at")

  book         Book           @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@index([bookId])
  @@index([traceId])
  @@index([createdAt(sort: Desc)])
  @@map("agent_logs")
}

// ═══════════════════════════════════════════
// GENERATION JOBS
// ═══════════════════════════════════════════

// Phase 3I: a typed, persisted record of one generation attempt (generate or
// retry), tracked alongside — not instead of — Book.status, which remains the
// source of truth for user-facing status. Since Phase 3K, scheduled on a
// durable BullMQ/Redis-backed queue (GenerationQueueService/
// GenerationQueueProcessor), not in-process; see
// apps/api/docs/local-generation-pipeline.md.
model GenerationJob {
  id           String              @id @default(uuid()) @db.Uuid
  bookId       String              @map("book_id") @db.Uuid
  userId       String              @map("user_id") @db.Uuid
  type         GenerationJobType
  status       GenerationJobStatus @default(queued)
  attempt      Int                 @default(1)
  maxAttempts  Int?                @map("max_attempts")
  failedStep   AgentStep?          @map("failed_step")
  errorMessage String?             @map("error_message")
  runnerId     String?             @map("runner_id")

  createdAt    DateTime            @default(now()) @map("created_at")
  startedAt    DateTime?           @map("started_at")
  completedAt  DateTime?           @map("completed_at")
  failedAt     DateTime?           @map("failed_at")
  updatedAt    DateTime            @updatedAt @map("updated_at")

  book         Book                @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@index([bookId])
  @@index([bookId, status])
  @@map("generation_jobs")
}

// ═══════════════════════════════════════════
// GENERATION RUNS (Phase 2A — schema only; wired in by Phase 2B)
// ═══════════════════════════════════════════

// One generation attempt, replacing GenerationJob as the dispatch/fencing
// source of truth. Carries its own immutable input snapshot (so a retry
// resumes the exact input a prior run used, while a regenerate captures the
// book's *current* fields at creation time — see AgentService's
// isResumableBook, which this replaces) and a lease/fencingVersion pair so a
// stale worker can never overwrite a newer run or the published book (see
// "State-transition table" in docs/local-generation-pipeline.md once Phase
// 2B lands). A partial unique index (added via raw SQL below, since Prisma
// has no native conditional-unique syntax) enforces at most one active
// (queued/running) run per book at the database level — Book.activeRunId
// alone is an application-level mirror of that invariant, not its enforcement.
model GenerationRun {
  id             String              @id @default(uuid()) @db.Uuid
  bookId         String              @map("book_id") @db.Uuid
  userId         String              @map("user_id") @db.Uuid
  kind           GenerationRunKind
  status         GenerationRunStatus @default(queued)
  // Immutable copy of the book's generation-relevant fields at run-creation
  // time (childName, childAge, language, theme, educationalMessage,
  // pageCount, childPhotoAssetKey, childPhotoContentType).
  inputSnapshot  Json                @map("input_snapshot")
  // sha256 of a canonical serialization of inputSnapshot — lets the frontend
  // (Phase 5) derive "this edit hasn't been generated yet" without a second
  // round-trip.
  inputHash      String              @map("input_hash")
  // Set only when kind = retry — the run being retried, whose inputSnapshot
  // this run reuses verbatim. Plain UUID, not a Prisma self-relation: see the
  // note on Book.activeRunId/publishedRunId above for why.
  retryOfRunId   String?             @map("retry_of_run_id") @db.Uuid
  currentStep    AgentStep?          @map("current_step")
  attempt        Int                 @default(1)
  leaseOwner     String?             @map("lease_owner")
  leaseExpiresAt DateTime?           @map("lease_expires_at")
  // Incremented on every guarded claim/heartbeat/recovery-forced-failure —
  // every mutation this run makes must condition its WHERE clause on the
  // fencingVersion it last observed, so a stale worker's late write matches
  // zero rows instead of resurrecting a run recovery already failed.
  fencingVersion Int                 @default(0) @map("fencing_version")
  errorCode      String?             @map("error_code")
  errorMessage   String?             @map("error_message")

  startedAt      DateTime?           @map("started_at")
  completedAt    DateTime?           @map("completed_at")
  failedAt       DateTime?           @map("failed_at")
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")

  book           Book                @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@index([bookId])
  @@index([userId])
  @@map("generation_runs")
}

// Transactional outbox: created in the same DB transaction as the
// GenerationRun it announces, so a crash between "commit the run" and
// "publish to BullMQ" can never permanently lose the dispatch — a periodic
// sweep (Phase 2B's OutboxDispatcherService) publishes every still-`pending`
// event, using aggregateId as the BullMQ jobId so a re-swept event is an
// idempotent no-op rather than a duplicate job.
model OutboxEvent {
  id            String    @id @default(uuid()) @db.Uuid
  aggregateType String    @map("aggregate_type")
  aggregateId   String    @map("aggregate_id") @db.Uuid
  eventType     String    @map("event_type")
  payload       Json
  status        String    @default("pending")
  attempts      Int       @default(0)
  createdAt     DateTime  @default(now()) @map("created_at")
  dispatchedAt  DateTime? @map("dispatched_at")

  @@index([status, createdAt])
  @@map("outbox_events")
}

// ═══════════════════════════════════════════
// USER BOOK STATES
// ═══════════════════════════════════════════

model UserBookState {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  bookId    String    @map("book_id") @db.Uuid
  lastPage  Int       @default(1) @map("last_page")
  bookmarks Int[]     @default([])
  updatedAt DateTime  @updatedAt @map("updated_at")

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  book      Book      @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([userId, bookId])
  @@map("user_book_states")
}

// ═══════════════════════════════════════════
// NOTIFICATIONS
// ═══════════════════════════════════════════

model Notification {
  id        String              @id @default(uuid()) @db.Uuid
  userId    String              @map("user_id") @db.Uuid
  type      NotificationType
  channel   NotificationChannel
  title     String
  body      String
  data      Json?
  readAt    DateTime?           @map("read_at")
  sentAt    DateTime?           @map("sent_at")
  createdAt DateTime            @default(now()) @map("created_at")

  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@map("notifications")
}
