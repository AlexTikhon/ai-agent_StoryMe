# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://storyme:storyme_dev@localhost:5432/storyme"

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── Auth ────────────────────────────────────────────────────────────────────
# Must be ≥32 chars; generate with: openssl rand -hex 32
# JWT_SECRET signs access tokens; JWT_REFRESH_SECRET is the HMAC key used to
# hash refresh tokens before they're stored in the RefreshToken table (the
# refresh token itself is an opaque random value, not a JWT).
JWT_SECRET="dev-jwt-secret-change-in-production-min-32-chars-00"
JWT_REFRESH_SECRET="dev-refresh-secret-change-in-prod-min-32-chars-000"

# AUTH_MODE: dev | jwt. Defaults to "jwt" (real email/password + JWT access
# token + rotating refresh cookie) when unset, so a deployment that forgets to
# set this is safe. "jwt" is also the recommended mode for local dev and for
# the private demo (see docs/local-demo.md, docs/private-demo-deploy.md) —
# register/login through the real UI instead of a trusted header. Set to
# "dev" only if you want the old header-based convenience (no login screen,
# single shared dev user) — DevAuthGuard trusts an x-user-email header with
# no credential check and auto-provisions a user. DevAuthGuard refuses to run
# when NODE_ENV=production regardless of this setting, as a second safety net.
# Must match apps/web/.env.example's NEXT_PUBLIC_AUTH_MODE — a mismatch means
# every request from the web app 401s (dev sends x-user-email headers, jwt
# sends a bearer token; the two guards don't accept each other's identity).
AUTH_MODE="jwt"

# ─── Auth rate limiting (Phase 6E) ────────────────────────────────────────────
# Applies to POST /api/auth/{register,login,refresh,logout}. In-memory,
# single-process fixed-window limiter (apps/api/src/rate-limit/) — correct for
# the current single-instance deploy; a multi-instance deploy needs a shared
# store (e.g. Redis) behind the same interface. Defaults are generous enough
# not to interfere with normal local dev/demo usage while still capping
# credential-stuffing/brute-force attempts. Exceeding the limit returns
# 429 { "error": "Too many requests", "code": "RATE_LIMITED" }.
# AUTH_RATE_LIMIT_WINDOW_MS="900000"    # 15 minutes
# AUTH_RATE_LIMIT_MAX_ATTEMPTS="10"

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=4000
ALLOWED_ORIGINS="http://localhost:3000"
NODE_ENV=development

# Web app origin — used only to build links sent in transactional email (e.g.
# the email verification link). Defaults to the local web dev server.
WEB_APP_URL="http://localhost:3000"

# ─── Email verification (Phase 6F) ────────────────────────────────────────────
# No real email provider is wired up yet. ConsoleEmailService (the only
# EmailService implementation today) logs the verification link instead of
# sending it — see docs/auth-architecture.md. A real provider (Resend/SES/etc.)
# is a drop-in swap behind the EmailService interface (apps/api/src/email/)
# whenever one is added; no env var is needed until then.

# ─── AI Providers ────────────────────────────────────────────────────────────
# OPENAI_API_KEY is only required when STORY_GENERATION_PROVIDER or
# IMAGE_GENERATION_PROVIDER_TOKEN is set to "openai" below (enforced by
# env.schema.ts at startup). Leave unset for the default mock/mock config —
# the API boots fine with no OpenAI credentials at all in that case.
# OPENAI_API_KEY="sk-replace-with-real-key"
# ANTHROPIC_API_KEY / FAL_API_KEY: reserved for providers not wired up yet —
# no code path reads them, so they're optional and safe to leave unset.
# ANTHROPIC_API_KEY="sk-ant-api03-replace-with-real-key"
# FAL_API_KEY="replace-with-real-fal-key"

# ─── Story generation provider ────────────────────────────────────────────────
# mock (default) | openai. Missing/empty/"mock" always uses the deterministic
# local MockStoryGenerationProvider — no network calls, safe for tests/CI.
# Setting "openai" requires OPENAI_API_KEY above and calls the real OpenAI API.
STORY_GENERATION_PROVIDER="mock"
# OPENAI_MODEL="gpt-4o-mini"  # only used when STORY_GENERATION_PROVIDER=openai

# ─── Image generation provider ────────────────────────────────────────────────
# mock (default) | openai. Missing/empty/"mock" always uses the deterministic
# local MockImageGenerationProvider — no network calls, safe for tests/CI.
# Setting "openai" requires OPENAI_API_KEY above and calls the real OpenAI
# images API. Real image generation costs money per call — see the
# REAL_GENERATION_MAX_PAGES guardrail below.
IMAGE_GENERATION_PROVIDER_TOKEN="mock"
# OPENAI_IMAGE_MODEL="gpt-image-1"  # only used when IMAGE_GENERATION_PROVIDER_TOKEN=openai

# ─── Real provider request hardening (Phase 3D) ───────────────────────────────
# Only used by OpenAIStoryGenerationProvider / OpenAIImageGenerationProvider —
# no effect on the mock providers. Safe defaults apply when unset.
# OPENAI_REQUEST_TIMEOUT_MS="60000"  # per-attempt request timeout (AbortController)
# OPENAI_MAX_RETRIES="2"             # retries on network errors, timeouts, and HTTP 408/429/500/502/503/504 only

# ─── Real generation cost guardrail (Phase 3D) ────────────────────────────────
# Only enforced by OpenAIImageGenerationProvider (real, paid image calls) — the
# mock image provider is unaffected. Requests for a page beyond this number
# are rejected with a clear error before any network call is made.
# REAL_GENERATION_MAX_PAGES="12"

# ─── Generation job recovery (Phase 3J) ───────────────────────────────────────
# How long (ms) a queued/running GenerationJob can sit before startup recovery
# treats it as stale (from a previous process that died/restarted) and marks
# the job + book failed. Defaults to 30 minutes when unset.
# GENERATION_JOB_STALE_AFTER_MS="1800000"

# To run the full real story + image generation pipeline once, end-to-end,
# against a local Postgres/Redis (manual, never part of CI/tests):
#   pnpm --filter @book/api smoke:real-generation
# Requires OPENAI_API_KEY plus STORY_GENERATION_PROVIDER=openai and
# IMAGE_GENERATION_PROVIDER_TOKEN=openai set above.
# Full runbook: apps/api/docs/local-generation-pipeline.md

# ─── Storage (Cloudflare R2 / local MinIO) ───────────────────────────────────
# Reserved for the future Upload feature (child photo uploads) — no code path
# reads these yet, so they're optional. Local MinIO values shown for when that
# feature lands:
# R2_ACCOUNT_ID="local"
# R2_ACCESS_KEY_ID="storyme"
# R2_SECRET_ACCESS_KEY="storyme_dev_secret"
# R2_BUCKET_NAME="storyme-dev"
# R2_ENDPOINT="http://localhost:9000"
# R2_PUBLIC_URL="http://localhost:9000/storyme-dev"

# ─── PDF preview storage ──────────────────────────────────────────────────────
# driver: local (default) | s3 | r2. s3/r2 require the PDF_STORAGE_* vars below.
PDF_STORAGE_DRIVER="local"
# PDF_STORAGE_BUCKET="storyme-previews"
# PDF_STORAGE_REGION="auto"
# PDF_STORAGE_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"  # required for r2
# PDF_STORAGE_ACCESS_KEY_ID="replace-with-real-key"
# PDF_STORAGE_SECRET_ACCESS_KEY="replace-with-real-secret"
# PDF_STORAGE_FORCE_PATH_STYLE="true"  # optional, defaults to true when PDF_STORAGE_ENDPOINT is set
#
# AWS S3 example:
#   PDF_STORAGE_DRIVER="s3"
#   PDF_STORAGE_BUCKET="storyme-previews"
#   PDF_STORAGE_REGION="us-east-1"
#   PDF_STORAGE_ACCESS_KEY_ID="replace-with-real-key"
#   PDF_STORAGE_SECRET_ACCESS_KEY="replace-with-real-secret"
#
# Cloudflare R2 example:
#   PDF_STORAGE_DRIVER="r2"
#   PDF_STORAGE_BUCKET="storyme-previews"
#   PDF_STORAGE_REGION="auto"
#   PDF_STORAGE_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"
#   PDF_STORAGE_ACCESS_KEY_ID="replace-with-real-key"
#   PDF_STORAGE_SECRET_ACCESS_KEY="replace-with-real-secret"
#   PDF_STORAGE_FORCE_PATH_STYLE="true"
#
# To verify s3/r2 credentials against a REAL bucket (manual, not part of CI/tests):
#   pnpm --filter @book/api smoke:pdf-storage
# Full runbook: apps/api/docs/pdf-storage-smoke-test.md

# ─── Generated image asset storage ────────────────────────────────────────────
# driver: local (default) | s3 | r2. s3/r2 reuse the SAME PDF_STORAGE_* bucket
# and credential vars above (bucket, region, endpoint, access key, secret,
# force-path-style) — generated images are stored in the same bucket under an
# "images/" prefix instead of a separate bucket, so no new credential vars are
# needed. Only the driver selection is independent, so PDF previews and image
# assets can each opt into cloud storage on their own.
IMAGE_STORAGE_DRIVER="local"
#
# Cloudflare R2 example (uses the PDF_STORAGE_* vars set above):
#   IMAGE_STORAGE_DRIVER="r2"
#
# AWS S3 example (uses the PDF_STORAGE_* vars set above):
#   IMAGE_STORAGE_DRIVER="s3"

# ─── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_replace_with_real_key"
STRIPE_WEBHOOK_SECRET="whsec_replace_with_real_secret"
STRIPE_PRICE_ID_PAY_PER_BOOK="price_replace"
STRIPE_PRICE_ID_FAMILY_MONTHLY="price_replace"
STRIPE_PRICE_ID_FAMILY_ANNUAL="price_replace"
STRIPE_PRICE_ID_EDUCATOR="price_replace"

# ─── OAuth (optional) ────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID="replace-with-google-client-id"
GOOGLE_CLIENT_SECRET="replace-with-google-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:4000/api/auth/google/callback"
