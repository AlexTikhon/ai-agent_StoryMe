# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://storyme:storyme_dev@localhost:5432/storyme"

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── Auth ────────────────────────────────────────────────────────────────────
# Must be ≥32 chars; generate with: openssl rand -hex 32
# JWT_SECRET signs access tokens; JWT_REFRESH_SECRET is the HMAC key used to
# hash refresh tokens before they're stored in the RefreshToken table (the
# refresh token itself is an opaque random value, not a JWT).
JWT_SECRET="dev-jwt-secret-change-in-production-min-32-chars-00"
JWT_REFRESH_SECRET="dev-refresh-secret-change-in-prod-min-32-chars-000"

# AUTH_MODE: dev | jwt. Defaults to "jwt" (real email/password + JWT access
# token + rotating refresh cookie) when unset, so a deployment that forgets to
# set this is safe. "jwt" is also the recommended mode for local dev and for
# the private demo (see docs/local-demo.md, docs/private-demo-deploy.md) —
# register/login through the real UI instead of a trusted header. Set to
# "dev" only if you want the old header-based convenience (no login screen,
# single shared dev user) — DevAuthGuard trusts an x-user-email header with
# no credential check and auto-provisions a user. DevAuthGuard refuses to run
# when NODE_ENV=production regardless of this setting, as a second safety net.
# Must match apps/web/.env.example's NEXT_PUBLIC_AUTH_MODE — a mismatch means
# every request from the web app 401s (dev sends x-user-email headers, jwt
# sends a bearer token; the two guards don't accept each other's identity).
AUTH_MODE="jwt"

# ─── Auth rate limiting (Phase 6E) ────────────────────────────────────────────
# Applies to POST /api/auth/{register,login,refresh,logout}. In-memory,
# single-process fixed-window limiter (apps/api/src/rate-limit/) — correct for
# the current single-instance deploy; a multi-instance deploy needs a shared
# store (e.g. Redis) behind the same interface. Defaults are generous enough
# not to interfere with normal local dev/demo usage while still capping
# credential-stuffing/brute-force attempts. Exceeding the limit returns
# 429 { "error": "Too many requests", "code": "RATE_LIMITED" }.
# AUTH_RATE_LIMIT_WINDOW_MS="900000"    # 15 minutes
# AUTH_RATE_LIMIT_MAX_ATTEMPTS="10"

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=4000
ALLOWED_ORIGINS="http://localhost:3000"
NODE_ENV=development

# ─── Generation worker (Phase 3K "Worker process separation") ────────────────
# Generation jobs (POST /:id/generate, /:id/retry-generation) run on a durable
# BullMQ/Redis queue that only a process registering GenerationQueueProcessor
# actually consumes — without a worker, a book sits in char_build (or any
# non-terminal status) forever with a queued job nothing ever picks up.
# true (default here, for local dev): the API process (`pnpm --filter @book/api
#   dev`) also registers the worker, so a single process/terminal is enough.
# false/unset: the API never consumes jobs — you must also run
#   `pnpm --filter @book/api dev:worker` in a second terminal. This is the
#   required setting for every deployed environment (see "Worker process
#   separation" in apps/api/docs/local-generation-pipeline.md) — API and
#   worker scale independently there, each as its own service.
ENABLE_GENERATION_WORKER="true"

# Web app origin — used only to build links sent in transactional email (e.g.
# the email verification link). Defaults to the local web dev server.
WEB_APP_URL="http://localhost:3000"

# ─── Transactional email provider (Phase 6H) ─────────────────────────────────
# EMAIL_PROVIDER: console (default) | resend. Missing/empty/"console" always
# uses ConsoleEmailService — logs the verification/reset link instead of
# sending it, no network calls, safe for local dev/tests/CI. Setting "resend"
# calls the real Resend API (https://resend.com) and requires RESEND_API_KEY +
# EMAIL_FROM below (enforced by env.schema.ts at startup — fails fast if
# either is missing). See docs/auth-architecture.md §16.
EMAIL_PROVIDER="console"
# RESEND_API_KEY="re_replace_with_real_key"        # only used when EMAIL_PROVIDER=resend
# EMAIL_FROM="StoryMe <noreply@storyme.app>"        # must be a verified sender/domain in Resend
# EMAIL_REPLY_TO="support@storyme.app"              # optional

# MVP-testing fallback only. When EMAIL_PROVIDER is unset/"console" AND
# NODE_ENV=production, the raw verification/reset link (contains a live
# token) is suppressed from logs by default — only an error noting
# misconfiguration is logged. Set this to "true" to temporarily log the
# link (email + URL only) to Railway logs while a real provider isn't wired
# up yet. Leave unset/false once EMAIL_PROVIDER=resend is configured.
# EMAIL_DEBUG_LOG_LINKS="true"

# ─── AI Providers ────────────────────────────────────────────────────────────
# OPENAI_API_KEY is only required when STORY_GENERATION_PROVIDER or
# IMAGE_GENERATION_PROVIDER is set to "openai" below (enforced by
# env.schema.ts at startup). Leave unset for the default mock/mock config —
# the API boots fine with no OpenAI credentials at all in that case.
# OPENAI_API_KEY="sk-replace-with-real-key"
# ANTHROPIC_API_KEY / FAL_API_KEY: reserved for providers not wired up yet —
# no code path reads them, so they're optional and safe to leave unset.
# ANTHROPIC_API_KEY="sk-ant-api03-replace-with-real-key"
# FAL_API_KEY="replace-with-real-fal-key"

# ─── Story generation provider ────────────────────────────────────────────────
# mock (default) | openai. Missing/empty/"mock" always uses the deterministic
# local MockStoryGenerationProvider — no network calls, safe for tests/CI.
# Setting "openai" requires OPENAI_API_KEY above and calls the real OpenAI API.
STORY_GENERATION_PROVIDER="mock"
# OPENAI_STORY_MODEL="gpt-4o-mini"  # only used when STORY_GENERATION_PROVIDER=openai

# ─── Image generation provider ────────────────────────────────────────────────
# mock (default) | openai. Missing/empty/"mock" always uses the deterministic
# local MockImageGenerationProvider — no network calls, safe for tests/CI.
# Setting "openai" requires OPENAI_API_KEY above and calls the real OpenAI
# images API. Real image generation costs money per call — see the
# REAL_GENERATION_MAX_PAGES / MAX_GENERATED_IMAGES_PER_BOOK guardrails below.
IMAGE_GENERATION_PROVIDER="mock"
# OPENAI_IMAGE_MODEL="gpt-image-1"  # only used when IMAGE_GENERATION_PROVIDER=openai

# ─── Real provider request hardening (Phase 3D) ───────────────────────────────
# Only used by OpenAIStoryGenerationProvider / OpenAICharacterProfileProvider
# (text requests) — no effect on the mock providers or on real image
# generation, which uses its own OPENAI_IMAGE_* timeout below. Safe defaults
# apply when unset.
# OPENAI_REQUEST_TIMEOUT_MS="60000"  # per-attempt request timeout (AbortController)
# OPENAI_MAX_RETRIES="2"             # retries on network errors, timeouts, and HTTP 408/429/500/502/503/504 only

# ─── Real image request timeout (separate from text requests above) ──────────
# Only used by OpenAIImageGenerationProvider. Real image generation/edit calls
# (gpt-image-1, especially the character-reference /images/edits multipart
# upload path) routinely take well over 60s, so they get their own, longer
# timeout instead of sharing OPENAI_REQUEST_TIMEOUT_MS with the (fast) text
# providers. A timeout retry is deliberately its own small, separately
# configured budget — a slow-but-working request shouldn't be retried into
# 2x/3x its own timeout. Network errors and HTTP 429 keep using the existing
# OPENAI_MAX_RETRIES / rate-limiter settings above/below, unaffected by this.
# OPENAI_IMAGE_REQUEST_TIMEOUT_MS="240000"  # per-attempt request timeout; must be 30000-600000, else falls back to 240000
# OPENAI_IMAGE_TIMEOUT_MAX_RETRIES="1"      # timeout-specific retries only; total attempts = 1 + this value

# ─── Real generation cost guardrail (Phase 3D) ────────────────────────────────
# Only enforced by OpenAIImageGenerationProvider (real, paid image calls) — the
# mock image provider is unaffected. Requests for a page beyond this number
# are rejected with a clear error before any network call is made.
# REAL_GENERATION_MAX_PAGES="12"

# ─── Illustration generation cost cap ─────────────────────────────────────────
# Only applies when IMAGE_GENERATION_PROVIDER=openai (real, paid image
# calls) — the free mock provider always generates every page. Caps how many
# of a book's images (cover, pages, back cover, in that order) AgentService
# actually sends to the real provider; the rest are skipped before any network
# call is made and simply have no illustration bytes. Every planned
# illustration must have real bytes for the PDF to render — if this cap (or
# any transient API error) leaves an illustration missing, the book fails at
# the pdf_render step instead of silently rendering a placeholder; see
# generatedImageCount/failedImageCount in
# GET /api/books/:id/generation-diagnostics for which pages failed. Set this
# to at least the book's total illustration count (cover + pages + back
# cover) for a full real-image run, or pick a shorter pageCount to keep both
# the count and the bill small. Defaults to 3 when unset.
# MAX_GENERATED_IMAGES_PER_BOOK="3"

# ─── Generation job recovery (Phase 3J) ───────────────────────────────────────
# How long (ms) a queued/running GenerationJob can sit before startup recovery
# treats it as stale (from a previous process that died/restarted) and marks
# the job + book failed. Defaults to 30 minutes when unset.
# GENERATION_JOB_STALE_AFTER_MS="1800000"

# To run the full real story + image generation pipeline once, end-to-end,
# against a local Postgres/Redis (manual, never part of CI/tests):
#   pnpm --filter @book/api smoke:real-generation
# Requires OPENAI_API_KEY plus STORY_GENERATION_PROVIDER=openai and
# IMAGE_GENERATION_PROVIDER=openai set above.
# Full runbook: apps/api/docs/local-generation-pipeline.md

# ─── Storage (Cloudflare R2 / local MinIO) ───────────────────────────────────
# Reserved for the future Upload feature (child photo uploads) — no code path
# reads these yet, so they're optional. Local MinIO values shown for when that
# feature lands:
# R2_ACCOUNT_ID="local"
# R2_ACCESS_KEY_ID="storyme"
# R2_SECRET_ACCESS_KEY="storyme_dev_secret"
# R2_BUCKET_NAME="storyme-dev"
# R2_ENDPOINT="http://localhost:9000"
# R2_PUBLIC_URL="http://localhost:9000/storyme-dev"

# ─── PDF preview storage ──────────────────────────────────────────────────────
# driver: local (default) | s3 | r2. s3/r2 require the PDF_STORAGE_* vars below.
PDF_STORAGE_DRIVER="local"
# PDF_STORAGE_BUCKET="storyme-previews"
# PDF_STORAGE_REGION="auto"
# PDF_STORAGE_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"  # required for r2
# PDF_STORAGE_ACCESS_KEY_ID="replace-with-real-key"
# PDF_STORAGE_SECRET_ACCESS_KEY="replace-with-real-secret"
# PDF_STORAGE_FORCE_PATH_STYLE="true"  # optional, defaults to true when PDF_STORAGE_ENDPOINT is set
#
# AWS S3 example:
#   PDF_STORAGE_DRIVER="s3"
#   PDF_STORAGE_BUCKET="storyme-previews"
#   PDF_STORAGE_REGION="us-east-1"
#   PDF_STORAGE_ACCESS_KEY_ID="replace-with-real-key"
#   PDF_STORAGE_SECRET_ACCESS_KEY="replace-with-real-secret"
#
# Cloudflare R2 example:
#   PDF_STORAGE_DRIVER="r2"
#   PDF_STORAGE_BUCKET="storyme-previews"
#   PDF_STORAGE_REGION="auto"
#   PDF_STORAGE_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"
#   PDF_STORAGE_ACCESS_KEY_ID="replace-with-real-key"
#   PDF_STORAGE_SECRET_ACCESS_KEY="replace-with-real-secret"
#   PDF_STORAGE_FORCE_PATH_STYLE="true"
#
# To verify s3/r2 credentials against a REAL bucket (manual, not part of CI/tests):
#   pnpm --filter @book/api smoke:pdf-storage
# Full runbook: apps/api/docs/pdf-storage-smoke-test.md

# ─── Generated image asset storage ────────────────────────────────────────────
# driver: local (default) | s3 | r2. s3/r2 reuse the SAME PDF_STORAGE_* bucket
# and credential vars above (bucket, region, endpoint, access key, secret,
# force-path-style) — generated images are stored in the same bucket under an
# "images/" prefix instead of a separate bucket, so no new credential vars are
# needed. Only the driver selection is independent, so PDF previews and image
# assets can each opt into cloud storage on their own.
IMAGE_STORAGE_DRIVER="local"
#
# Cloudflare R2 example (uses the PDF_STORAGE_* vars set above):
#   IMAGE_STORAGE_DRIVER="r2"
#
# AWS S3 example (uses the PDF_STORAGE_* vars set above):
#   IMAGE_STORAGE_DRIVER="s3"

# ─── Orphaned claim-artifact cleanup (Phase C) ────────────────────────────────
# Storage-listing sweeper that deletes claim-scoped image/PDF artifacts (see
# apps/api/src/agent/claim-artifact-cleanup.service.ts) once nothing
# references them anymore: not the published PDF/images, not the resumable
# JSON's backing artifacts, not any fencing version under a book's currently
# active run, and older than CLAIM_CLEANUP_RETENTION_MS. Safe by default —
# disabled AND dry-run, so both must be explicitly turned on for real
# deletions to happen.
CLAIM_CLEANUP_ENABLED="false"
CLAIM_CLEANUP_DRY_RUN="true"
# How long (ms) a claim namespace must sit untouched (by the storage driver's
# own reported lastModified) before it's even eligible for deletion, no matter
# what the DB says. Must comfortably exceed RECOVERY_LEASE_MS (enforced at
# boot — the app refuses to start with CLAIM_CLEANUP_ENABLED=true and a
# retention window too close to it) so a namespace a live-but-momentarily-stale
# worker is still writing to can never look "old enough" to delete. Defaults
# to 24 hours.
# CLAIM_CLEANUP_RETENTION_MS="86400000"
# How often (ms) a new sweep pass starts. Defaults to 30 minutes.
# CLAIM_CLEANUP_INTERVAL_MS="1800000"
# Dedicated RecoveryLease row TTL (ms) for this service's own leader election —
# a separate lease id from GenerationRunRecoveryService's, so the two sweeps
# never contend for the same row. Defaults to 10 minutes.
# CLAIM_CLEANUP_LEASE_MS="600000"
# Requested page size per storage list call (every driver additionally clamps
# to its own provider limit — S3/R2 max 1000 keys per ListObjectsV2 call).
# CLAIM_CLEANUP_PAGE_SIZE="500"
# Safety caps bounding a single pass's work — total raw objects listed across
# both storage drivers, and total namespaces classified/deleted — before the
# pass stops early and leaves the remainder for the next scheduled pass.
# CLAIM_CLEANUP_MAX_OBJECTS_PER_PASS="10000"
# CLAIM_CLEANUP_MAX_NAMESPACES_PER_PASS="200"
# How many deleteClaimArtifacts calls for one namespace may be in flight at
# once (bounded parallelism, not a raw throughput target).
# CLAIM_CLEANUP_DELETE_CONCURRENCY="5"
#
# Rollout runbook (disabled -> dry-run -> one instance -> gradual expansion),
# rollback (CLAIM_CLEANUP_ENABLED=false, no DB rollback needed/deleted
# artifacts are not restorable), and the local-filesystem TOCTOU hardening:
# apps/api/docs/local-generation-pipeline.md, "Phase C — Orphaned
# claim-artifact cleanup: operations runbook".

# ─── Stripe billing (Phase E3 — one-time credit purchases only) ──────────────
# STRIPE_BILLING_ENABLED: false (default) | true. Safe by default — checkout
# fails closed with a stable BILLING_DISABLED error and no Stripe client is
# ever constructed while this is false. Flipping to "true" makes
# env.schema.ts's startup validation REQUIRE every var below (secret key,
# webhook secret, all three package Price IDs) — a partially configured
# enabled deployment fails fast at boot with a clear, non-secret error
# instead of failing (or worse, silently misbehaving) at first checkout.
STRIPE_BILLING_ENABLED="false"
# Stripe test-mode secret key (dashboard: Developers → API keys). Never a
# live key in any environment this repo's tests/CI touch.
# STRIPE_SECRET_KEY="sk_test_replace_with_real_key"
# Signing secret for the POST /api/billing/webhook endpoint (dashboard:
# Developers → Webhooks → your endpoint → Signing secret, or `stripe
# listen --print-secret` for local testing with the Stripe CLI).
# STRIPE_WEBHOOK_SECRET="whsec_replace_with_real_secret"
# Server-owned credit package catalog (apps/api/src/billing/billing-packages.ts)
# — each Price ID must be a Stripe one-time (not recurring) Price for the
# matching credit amount. A client only ever sends the public package id
# ("starter" | "pro" | "bundle"); it never sends a Price ID or amount.
# STRIPE_PRICE_ID_STARTER="price_replace"   # starter package — 10 credits
# STRIPE_PRICE_ID_PRO="price_replace"       # pro package — 30 credits
# STRIPE_PRICE_ID_BUNDLE="price_replace"    # bundle package — 100 credits
#
# Redis-backed per-user rate limit on POST /api/billing/checkout. Defaults
# shown; uncomment to override.
# BILLING_CHECKOUT_RATE_LIMIT_WINDOW_MS="3600000"  # 1 hour
# BILLING_CHECKOUT_RATE_LIMIT_MAX_ATTEMPTS="10"
#
# Subscriptions, the customer portal, promotional codes, and pay-per-book
# PaymentIntents are NOT implemented — see apps/api/docs/credits.md,
# "Phase E3", "Not in scope".

# ─── OAuth (optional) ────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID="replace-with-google-client-id"
GOOGLE_CLIENT_SECRET="replace-with-google-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:4000/api/auth/google/callback"
