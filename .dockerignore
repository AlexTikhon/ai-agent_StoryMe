# Docker build context is the repo root (see apps/api/Dockerfile's root-relative
# COPY commands), so this is the .dockerignore Docker actually reads — a
# per-package .dockerignore (e.g. apps/api/.dockerignore) has no effect here.

# Dependencies (reinstalled in the deps stage; local trees are host-specific
# and would otherwise be copied verbatim by `COPY apps/api ./apps/api` etc.)
node_modules
**/node_modules

# Build outputs (regenerated by the builder stage)
dist
**/dist
.next
**/.next
**/.turbo
.turbo
.pnpm-store
**/.pnpm-store
*.tsbuildinfo

# Secrets — never send local .env files into a build context
.env
.env.*
!.env.example
!**/.env.example

# Local runtime/private data (processed child photos, generated images/PDFs)
tmp
**/tmp
uploads
**/uploads
*.db
*.db3
*.sqlite
*.sqlite3
*.dump
*.backup
*.pdf
*.jpg
*.jpeg
*.png
*.webp

# VCS / editor / docs noise not needed for the build
.git
.vscode
.idea
.DS_Store
Thumbs.db
desktop.ini
coverage
**/coverage
storyme-clean-*.tar.gz
